{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "未来時計",
  "version": "0.1.0",
  "identifier": "com.mirai-clock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3848"
  },
  "app": {
    "windows": [
      {
        "title": "未来時計",
        "width": 400,
        "height": 400,
        "minWidth": 200,
        "minHeight": 200,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
